{
  "name": "@mint-copilot/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mint-copilot/blockchain": "workspace:*",
    "@mint-copilot/gas-engine": "workspace:*",
    "@mint-copilot/logger": "workspace:*",
    "@mint-copilot/opensea": "workspace:*",
    "@mint-copilot/rpc-pool": "workspace:*",
    "@mint-copilot/shared": "workspace:*",
    "@mint-copilot/wallet-crypto": "workspace:*",
    "@prisma/client": "^6.2.1",
    "bullmq": "^5.34.2",
    "ioredis": "^5.4.2",
    "tsx": "^4.19.2",
    "viem": "^2.22.17"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
