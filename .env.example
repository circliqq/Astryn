DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
REDIS_URL=redis://localhost:6379

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

JWT_SECRET=replace_me
OPENSEA_API_KEY=replace_me
ETHERSCAN_API_KEY=replace_me

BASE_RPC_PRIMARY=
BASE_RPC_BACKUP_1=
BASE_RPC_BACKUP_2=

ETH_RPC_PRIMARY=
ETH_RPC_BACKUP_1=
ETH_RPC_BACKUP_2=

MINT_PREP_LEAD_MS=90000
MINT_BROADCAST_TIMEOUT_MS=2500
MINT_RECEIPT_CONFIRMATIONS=1
MINT_RECEIPT_TIMEOUT_MS=120000

# Mainnet safety. Keep disabled until you intentionally want live mainnet signing/broadcasting.
MAINNET_SIGNING_ENABLED=false
MAINNET_TX_KILL_SWITCH=false

ENCRYPTION_MASTER_KEY=replace_with_32_byte_base64_key

# Python executable used by the OpenSea eligibility worker.
# Windows usually uses python or py; Linux/Docker usually uses python3.
PYTHON_CMD=python

NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

FLASHBOTS_AUTH_KEY=
ONEINCH_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

DISCORD_WEBHOOK_URL=

# Bot Warfare (Gas Competition Detection)
# Gas spike factor to trigger competition mode (default: 1.5 = 50% above baseline)
BOT_WARFARE_SPIKE_THRESHOLD=1.5
# How much to boost max fee when competition detected (default: 1.2 = +20%)
BOT_WARFARE_BOOST_MULTIPLIER=1.2

